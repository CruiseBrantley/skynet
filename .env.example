BOT_ACTIVITY=for John Connor

# === Twitch Integration ===
TWITCH_CLIENTID=your_twitch_client_id
TWITCH_SECRET=your_twitch_secret
TWITCH_LISTEN_PORT=3000

# === AI / LLM ===
OLLAMA_REMOTE_HOST=192.168.1.100
OLLAMA_REMOTE_PORT=11434
OLLAMA_REMOTE_MODEL=gemma4:26b
OLLAMA_LOCAL_MODEL=gemma4:e4b
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# === Image Generation (Optional) ===
SWARMUI_REMOTE_URL=http://192.168.1.100:7801
SWARMUI_LOCAL_URL=http://127.0.0.1:7801
COMFYUI_URL=http://127.0.0.1:7821
IMAGE_MODEL_DEFAULT=model.safetensors
IMAGE_MODEL_FLUX=flux.gguf

# === TTS (Optional) ===
TTS_MODEL=en_US-danny-low.onnx

# === Game Server Management (Optional) ===
STEAM_SSH_KEY=/path/to/.ssh/key
STEAM_SSH_HOST=user@192.168.1.100
STEAM_STEAMCMD_PATH=C:\\steamcmd\\steamcmd.exe

# === Networking ===
NGROK_AUTH_TOKEN=your_ngrok_token
NGROK_SUBDOMAIN=your-subdomain.ngrok-free.app

# === Notes System (Optional) ===
NOTESUSER=your_notes_username
NOTESPASS=your_notes_password
NOTESLOGIN=https://your-backend.com/api/users/login
NOTESPOST=https://your-backend.com/api/notes

# === External APIs ===
YOUTUBE_KEY=your_youtube_api_key
OPENAI_API_KEY=your_openai_api_key

# === Misc ===
OWNER_ID=your_discord_user_id
NODE_ENV=dev
